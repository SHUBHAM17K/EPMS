datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  password           String
  name               String
  role               String              // "ADMIN", "MANAGER", "EMPLOYEE"
  employeeId         String              @unique
  department         String?
  designation        String?
  phone              String?
  linkedin           String?
  bio                String?
  profilePicture     String?
  joiningDate        DateTime            @default(now())
  isActive           Boolean             @default(true)
  managerId          Int?
  manager            User?               @relation("OrganizationHierarchy", fields: [managerId], references: [id])
  subordinates       User[]              @relation("OrganizationHierarchy")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]              @relation("TaskAssignee")
  goals              Goal[]
  attendanceRecords  Attendance[]
  reviewsReceived    PerformanceReview[] @relation("EmployeeReviews")
  reviewsGiven       PerformanceReview[] @relation("ReviewerReviews")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Project {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  status      String          // "ACTIVE", "ON_HOLD", "COMPLETED", "ARCHIVED"
  priority    String          // "LOW", "MEDIUM", "HIGH"
  startDate   DateTime
  endDate     DateTime?
  members     ProjectMember[]
  tasks       Task[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectMember {
  id        Int     @id @default(autoincrement())
  userId    Int
  projectId Int
  role      String  // "LEAD", "MEMBER"
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   // "PENDING", "IN_PROGRESS", "COMPLETED"
  priority    String   // "LOW", "MEDIUM", "HIGH"
  dueDate     DateTime
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  Int
  assignee    User     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Goal {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  completion  Float    @default(0.0) // 0 to 100 %
  dueDate     DateTime
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id          Int       @id @default(autoincrement())
  userId      Int
  checkDate   String    // "YYYY-MM-DD" to enforce single daily record
  checkIn     DateTime
  checkOut    DateTime?
  hoursWorked Float     @default(0)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkDate])
}

model PerformanceReview {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  reviewerId    Int
  reviewType    String   // "MONTHLY", "QUARTERLY"
  communication Int      // 1 to 5
  technical     Int      // 1 to 5
  delivery      Int      // 1 to 5
  teamwork      Int      // 1 to 5
  leadership    Int      // 1 to 5
  kpiScore      Float    @default(0.0)
  overallScore  Float
  comments      String?
  employee      User     @relation("EmployeeReviews", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer      User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
